generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id            String   @id @default(cuid()) @map("_id")
  email         String   @unique
  name          String?
  phone         String?
  avatar        String?
  role          UserRole @default(PARTICULAR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cif           String?
  companyName   String?
  legalName     String?   // Razón Social de facturación
  licenseNumber String?
  password      String?
  surname       String?
  website       String?
  companyLogo   String?
  coverImage    String?
  licenseType   String?  @default("STARTER")
 mobile        String?
  tagline       String?
  zone          String?
  address       String?  // <-- NUEVO
  postalCode    String?  // <-- NUEVO
ambassadorProfile AmbassadorProfile?
  // Relaciones Básicas
  favorites                Favorite[]
  properties               Property[]
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]
  blocksOut                UserBlock[]             @relation("UserBlocksOut")
  blocksIn                 UserBlock[]             @relation("UserBlocksIn")

  // Inteligencia Táctica
  lastLoginAt  DateTime? @default(now())
  loginCount   Int       @default(0)
  lastActiveAt DateTime? @default(now())

  // 🔥 EL PUENTE SAAS (Agencia) - UNIFICADO
  assignments PropertyAssignment[]

  // ✅ Datos de Agencia
  agencyTrialStartedAt DateTime?
  agencyTrialEndsAt    DateTime?
  agencyGraceEndsAt    DateTime?

// --- 🎖️ SECCIÓN EMBAJADORES (NUEVO) ---
  
  // 1. Jerarquía (¿Quién es mi Comandante?)
  recruitedById String?
  recruitedBy   User?   @relation("AgencyRecruits", fields: [recruitedById], references: [id])
  
  // 2. Mi Tropa (Si soy Agencia, ¿a quién he reclutado?)
  recruits      User[]  @relation("AgencyRecruits")

  // 3. Mis Victorias (Leads que yo he generado como embajador)
  generatedLeads Lead[] @relation("AmbassadorLeads")

  // ✅ Relaciones Inversas
  subscription    Subscription?
  agencyContacts  AgencyContact[]
  agencyCampaigns Campaign[]
  agencyTasks     Task[]

  // 🔥 OPEN HOUSE
  openHouseAttendances OpenHouseAttendee[]

  // --- 🚀 STRATOSFERE AMBASSADOR ENGINE (NUEVO) ---
  ambassadorStats AmbassadorStats?
  affiliateClicks AffiliateClick[]
  commissions     Commission[]
  demands         B2bDemand[]
sentProposals     B2bProposal[] @relation("SentProposals")     
  receivedProposals B2bProposal[] @relation("ReceivedProposals") 

  // 👑 VANGUARD MARKET NETWORK
  zoneCampaigns   ZoneCampaign[]

  // 📡 ANTENA DE NOTIFICACIONES PUSH (EL RADAR DE EXPO) 🔥
  expoPushToken   String?
}
model Property {
  id      String  @id @default(cuid())
  refCode String? @unique
  userId  String?

  // Datos Físicos
  address   String
  city      String?
  region    String?
  postcode  String?
  latitude  Float?
  longitude Float?
  type      String  @default("Piso")
  floor     String?
  door      String?
  elevator  Boolean @default(false)
  mBuilt    Float
  rooms     Int
  baths     Int

  // Extras
  pool      Boolean @default(false)
  garage    Boolean @default(false)
  garden    Boolean @default(false)
  security  Boolean @default(false)
  terrace   Boolean @default(false)
  balcony   Boolean @default(false)
  storage   Boolean @default(false)
  ac        Boolean @default(false)
  heating   Boolean @default(false)
  furnished Boolean @default(false)

  // Detalles
  state       String?
  orientation String?
  exterior    Boolean? @default(true)

  // Marketing & Estadísticas
  title            String?
  description      String?
  mainImage        String?
  price            Float?
  communityFees    Float?
  selectedServices String[]
  status           String   @default("BORRADOR")
  views            Int      @default(0)
  photoViews       Int      @default(0) // ✅ Confirmado
  shareCount       Int      @default(0) // ✅ Confirmado
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  ownerSnapshot    Json?

  // Energía
  energyConsumption String?
  energyEmissions   String?
  energyPending     Boolean @default(false)

  // 🔥 SAAS: Multimedia & Legal
  videoUrl      String?
  tourUrl       String?
  simpleNoteUrl String?
  energyCertUrl String?

  // 🔥 SAAS: Pay to Win
  promotedTier  String    @default("FREE")
  isPromoted    Boolean   @default(false) // ✅ Confirmado
  promotedUntil DateTime?                 // ✅ Confirmado

  // 🔥 SAAS: B2B (Comisiones)
  mandateType     String? @default("ABIERTO")
  commissionPct   Float   @default(0)
  sharePct        Float   @default(0)
  shareVisibility String  @default("PRIVATE")

  // RELACIONES
  user User? @relation(fields: [userId], references: [id])

  // 🔥 CONEXIÓN CON AGENCIA
  assignment PropertyAssignment?

  images            Image[]
  favoritedBy       Favorite[]
  serviceOrders     ServiceOrder[]
  campaigns         Campaign[]
  tasks             Task[]
  openHouses        OpenHouse[]
// Añadir dentro de model Property:
  leads Lead[]
 // --- 🚀 STRATOSFERE AMBASSADOR ENGINE (NUEVO) ---
  // Estas dos líneas son OBLIGATORIAS para que no falle el schema
  affiliateClicks AffiliateClick[]
  commissions     Commission[]
isPremium  Boolean  @default(false)
  isFire     Boolean  @default(false)

 // 👑 VANGUARD MARKET NETWORK
  zoneCampaigns   ZoneCampaign[]

  // ⭐ COMANDO TOP 10 (NUEVO)
  isTop10          Boolean?  @default(false)
  top10City        String?
  top10ExpiresAt   DateTime?
  top10CustomLogo  String?   // 🔥 NUEVO: Para machacar el logo automático
  top10CustomImage String?   // 🔥 NUEVO: Para machacar la foto de la casa
}
model Image {
  id         String   @id @default(cuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model ServiceOrder {
  id        String  @id @default(cuid())
  serviceId String
  name      String
  price     Float
  paid      Boolean @default(false)

  // ✅ Tracking Mollie (pago único por publicar)
  provider      String?
  providerPayId String?

  // 🔥 AQUÍ ESTÁ LA CLAVE
  payStatus String @default("OPEN") @map("estado de pago")

  paidAt   DateTime?
  metadata Json?

  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([providerPayId])
  @@index([payStatus])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

// =========================================================
// 💬 CHAT GENERAL (Intra-usuario)
// =========================================================

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Contexto opcional (cuando nace desde una propiedad)
  propertyId  String?
  propertyRef String?

  participants ConversationParticipant[]
  messages     Message[]

  @@index([propertyId])
  @@index([updatedAt])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime  @default(now())
  lastReadAt     DateTime? @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocksOut", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocksIn", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum UserRole {
  ADMIN
  PARTICULAR
  AGENCIA
  DIFUSOR
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique // agencia = User
  plan               PlanCode @default(STARTER)
  status             String   @default("ACTIVE") // ACTIVE|PAST_DUE|CANCELED
  provider           String? // PADDLE | MOLLIE
  providerSubId      String? // subscription id (si aplica)
  providerCustomerId String? // Mollie customer id

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
}

model PlanUsage {
  id            String   @id @default(cuid())
  userId        String // agencia
  period        String // "2026-01"
  campaignsSent Int      @default(0) // contador mensual
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, period])
  @@index([userId])
}

model AgencyContact {
  id        String   @id @default(cuid())
  userId    String // agencia (User)
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum CommissionShareVisibility {
  PRIVATE
  AGENCIES
  PUBLIC
}

model Campaign {
  id         String         @id @default(cuid())
  propertyId String
  agencyId   String // User.id con role AGENCIA
  status     CampaignStatus @default(DRAFT)

  message    String? // propuesta
  serviceIds String[] // ids de tu catálogo (plano_3d, foto, etc.)
  signature  Json? // firma/aceptación (opcional, luego)

  conversationId String? // conecta con tu chat general
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agency   User     @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // ✅ Términos de propuesta (persistentes en BD)
  priceAtProposal  Float @default(0)
  commissionPct    Float @default(0)
  commissionIvaPct Float @default(0)

  // 🔥 CAMPOS NUEVOS PARA EL CONTRATO DETALLADO (VITALES PARA EL STOCK)
  mandateType String? @default("SIMPLE") // "EXCLUSIVE" | "SIMPLE" | "OPEN"
  valuation   Float?  @default(0) // Precio de valoración acordado
  duration    String? @default("6 Meses") // Texto libre: "6 Meses", "1 Año", etc.

  commissionSharePct        Float                     @default(0)
  commissionShareVisibility CommissionShareVisibility @default(AGENCIES)

  exclusiveMandate Boolean @default(true)
  exclusiveMonths  Int     @default(6)

  // ✅ Importes calculados (snapshot)
  commissionBaseEur  Float @default(0)
  commissionIvaEur   Float @default(0)
  commissionTotalEur Float @default(0)
  commissionShareEur Float @default(0)

// ⚖️ AUDITORÍA LEGAL (CAJA NEGRA)
  ownerDecisionAt    DateTime? // Cuándo aceptó el contrato
  revokedAt          DateTime? // Cuándo pulsó el Botón Rojo de ruptura

  @@unique([propertyId, agencyId]) // 1 campaña activa por propiedad+agencia (mínimo)
  @@index([propertyId])
  @@index([agencyId])
  @@index([status])
}

enum CampaignStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model PropertyAssignment {
  id String @id @default(cuid())

  // Conexiones (El puente)
  propertyId String  @unique // @unique es vital: 1 casa = 1 agencia asignada
  agencyId   String
  campaignId String?

  // Estado
  status String @default("ACTIVE") // ACTIVE | ENDED

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones (Los cables del puente)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agency   User     @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Índices de Velocidad
  @@index([agencyId])
  @@index([status])
}

model Task {
  id         String    @id @default(cuid())
  propertyId String
  agencyId   String
  campaignId String?
  type       String // "VISITA" | "PLANO_3D" | ...
  status     String    @default("TODO") // TODO|DOING|DONE
  dueAt      DateTime?
  payload    Json? // notas, ficheros, etc.
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agency   User     @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([agencyId])
}

enum PlanCode {
  STARTER
  PRO
  AGENCY
}

// =========================================================
// 🎉 OPEN HOUSE / EVENTOS DE AGENCIA
// =========================================================

model OpenHouse {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  startTime DateTime // Ej: 2024-10-20 10:00
  endTime   DateTime // Ej: 2024-10-20 14:00

  title       String?
  description String?
  amenities   String[] // ["DJ", "Catering", "Welcome Pack"]
  capacity    Int      @default(50)

  status String @default("SCHEDULED")

  attendees OpenHouseAttendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
}

model OpenHouseAttendee {
  id          String    @id @default(cuid())
  openHouseId String
  openHouse   OpenHouse @relation(fields: [openHouseId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  name  String?
  email String?
  phone String?

  status String @default("CONFIRMED")

  createdAt DateTime @default(now())

  @@unique([openHouseId, userId])
  @@index([openHouseId])
  @@index([email])
}

// --- 🚀 STRATOSFERE AMBASSADOR ENGINE ---

model AmbassadorStats {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Métricas
  totalClicks   Int      @default(0)
  totalLeads    Int      @default(0)
  totalSales    Int      @default(0)
  
  // Dinero
  totalRevenue  Float    @default(0) // Histórico generado
  pendingPayout Float    @default(0) // Bloqueado (Arras)
  availablePayout Float  @default(0) // Listo para retirar
  
  // Calidad
  score         Float    @default(5.0) 
  rank          String   @default("PARTNER") 
  
  updatedAt     DateTime @updatedAt
}

model AffiliateClick {
  id            String   @id @default(cuid())
  ambassadorId  String
  propertyId    String
  ipHash        String?  
  createdAt     DateTime @default(now())

  // Relaciones
  ambassador    User     @relation(fields: [ambassadorId], references: [id])
  property      Property @relation(fields: [propertyId], references: [id])
  
  @@index([ambassadorId])
  @@index([propertyId])
}

model Commission {
  id            String   @id @default(cuid())
  ambassadorId  String
  propertyId    String
  amount        Float
  status        String   @default("PENDING") // PENDING, LOCKED, AVAILABLE, PAID
  
  leadId        String?  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [ambassadorId], references: [id])
  property      Property @relation(fields: [propertyId], references: [id])
}

// EN: prisma/schema.prisma

// --- EXPEDIENTE DEL EMBAJADOR (DATOS FISCALES Y CONTACTO) ---
model AmbassadorProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  fullName  String?  // Nombre Fiscal / Razón Social
  dni       String?  // DNI / CIF
  phone     String?  // Teléfono Operativo
  city      String?  // Ciudad Base
  address   String?  // Dirección Fiscal
  iban      String?  // Para pagos
  
  updatedAt DateTime @updatedAt
}

// 📩 BUZÓN DE LEADS (INTERESADOS EXTERNOS)
model Lead {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Datos del Interesado
  name         String
  email        String
  phone        String?
  message      String?
  
  // ¿Qué le interesa?
  propertyId   String
  // 🔥 AÑADIDO: onDelete: Cascade (Si borra la casa, se borran sus mensajes para no dejar basura)
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // ¿Quién gestiona este lead? 
  managerId    String? 

  // --- RASTREO (OPCIONAL) ---
  // Si es un cliente "puro", esto se quedará vacío (null), y no pasa nada.
  ambassadorId String?
  ambassador   User?    @relation("AmbassadorLeads", fields: [ambassadorId], references: [id])
  
  // 🔥 NUEVO: EL CHIVATO DE ROI PARA LAS CAMPAÑAS VIP
  source       String   @default("ORGANIC")
  campaignId   String?  

  // Estado del Lead
  status       String   @default("NEW") 
}

// =========================================================
// 🎯 CRM TÁCTICO: BASE DE DATOS DE CAPTACIÓN (OUTBOUND)
// =========================================================

model AgencyProspect {
  id          String   @id @default(cuid())
  
  // Datos de la Agencia Objetivo
  companyName String
  contactName String?  // Nombre del gerente (si lo sabemos)
  email       String   @unique
  phone       String?
  
  // Localización
  address     String?
  city        String?
  region      String?
  zipCode     String?
  
  // Estado Comercial
  status      String   @default("NEW") // NEW (Sin tocar), CONTACTED (Email enviado), REGISTERED (Ya se unió), DEAD (No interesa)
  notes       String?  // Para que usted ponga: "Llamar el martes"
  
  // Rastro
  emailsSent  Int      @default(0)
  lastContact DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([city])
}

// =========================================================
// 🗂️ ARCHIVOS Y DOCUMENTOS ENCRIPTADOS (BUZÓN SAAS)
// =========================================================

model StratosDocument {
  id           String   @id @default(cuid())
  fileName     String   
  fileUrl      String   
  sizeKB       String   
  propertyRef  String   
  ownerId      String   
  isRead       Boolean  @default(false)
  
  senderName   String?  // 👈 NUEVO: Nombre del remitente
  senderEmail  String?  // 👈 NUEVO: Email del remitente
  
  createdAt    DateTime @default(now())
  @@index([ownerId])
  @@index([propertyRef])
}

// =========================================================================
// 👑 VANGUARD MARKET NETWORK (DOMINIO DE ZONA B2B)
// =========================================================================
model ZoneCampaign {
  id                 String    @id @default(cuid())
  postalCode         String    @unique
  subtitle           String?
  customBio          String?
  isActive           Boolean   @default(true)
  expiresAt          DateTime?
  warning48hSent     Boolean   @default(false) 

  // 🛡️ NUEVOS CAMPOS DE SOBREESCRITURA (OVERRIDES)
  campaignLogo       String?  // Si se sube aquí, PISARÁ el companyLogo de la agencia
  campaignMainImage  String?  // Si se sube aquí, PISARÁ la mainImage de la casa

  // 🔥 MODO FRANCOTIRADOR: Coordenadas exactas de la oficina
  latitude           Float?
  longitude          Float?
  
  // Relaciones
  agencyId           String
  agency             User      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  propertyId         String
  property           Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  clicks             Int       @default(0) // Cuenta cuántas veces abren la tarjeta
  leads              Int       @default(0) // Cuenta cuántas veces pulsan contactar
}

// ==========================================
// 💶 CAJA FUERTE: ALBARANES TÁCTICOS
// ==========================================
model TacticalInvoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique // Ej: INV-448963
  agencyId      String?  // ID de la agencia (por si queremos enlazarla)
  agencyName    String   // Nombre de la agencia en el momento del disparo
  targetRef     String?  // Referencia de la propiedad (Ej: SF-NP7UE2)
  serviceType   String   // Ej: MARKET NETWORK VIP
  amount        Float    // Importe (Ej: 600)
  status        String   @default("PENDIENTE") // Estados: PENDIENTE, PAGADO, CADUCADO
  mollieLink    String?  // Guardamos el link por si hay que reenviarlo
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


// 📌 TABLA DE DEMANDAS B2B (MERCADO INVERSO)
model B2bDemand {
  id          String   @id @default(cuid())
  userId      String   // El ID del agente/embajador que la publica
  title       String
  location    String
  budget      String   // Ej: "Hasta 15.000.000 €"
  totalComm   String?
  split       String   // Ej: "50% / 50%"
  urgent      Boolean  @default(false)
  mandate     Boolean  @default(false)
  description String   @db.Text
  isActive    Boolean  @default(true) // Por si queremos pausarlas
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relación con el usuario que la crea (Asegúrese de que su modelo de usuarios se llame 'User')
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals   B2bProposal[]
}

// 📌 BUZÓN DE PROPUESTAS B2B (EL CHIVATO)
model B2bProposal {
  id          String    @id @default(cuid())
  demandId    String    // A qué demanda responde
  senderId    String    // Quién envía la propuesta (El cazador)
  receiverId  String    // Quién la recibe (El dueño de la demanda)

  mode        String    // "REF" o "OFF_MARKET"
  reference   String?   // Si usó el modo Plataforma
  phone       String?   // Si usó el modo Off-Market
  notes       String?   @db.Text // El mensaje secreto

  status      String    @default("UNREAD") // UNREAD, READ, CONTACTED

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  demand      B2bDemand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  sender      User      @relation("SentProposals", fields: [senderId], references: [id])
  receiver    User      @relation("ReceivedProposals", fields: [receiverId], references: [id])
}
